-- 切換到 PDB
ALTER SESSION SET CONTAINER = FREEPDB1;

-- 建立使用者（注意大小寫需與 .env 一致）
-- 這裡使用 IF NOT EXISTS 的概念（Oracle 23ai 支援）
CREATE USER ${ORACLE_USERNAME} IDENTIFIED BY ${ORACLE_PASSWORD};

-- 授予權限
GRANT CONNECT, RESOURCE, CREATE SESSION, CREATE VIEW, CREATE TABLE TO ${ORACLE_USERNAME};
GRANT INSERT ANY TABLE, UPDATE ANY TABLE, DELETE ANY TABLE, SELECT ANY TABLE TO ${ORACLE_USERNAME};

-- 設定配額
ALTER USER ${ORACLE_USERNAME} QUOTA UNLIMITED ON USERS;