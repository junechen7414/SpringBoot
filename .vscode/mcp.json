{
  "inputs": [
    {
      "id": "anthropic-base-url",
      "type": "promptString",
      "description": "Anthropic Base URL (ANTHROPIC_BASE_URL)"
    },
    {
      "id": "anthropic-auth-token",
      "type": "promptString",
      "description": "Anthropic Auth Token (ANTHROPIC_AUTH_TOKEN)",
      "password": true
    },
    {
      "id": "anthropic-model",
      "type": "promptString",
      "description": "Anthropic Model name (ANTHROPIC_MODEL)"
    }
  ],
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${env:GITHUB_PAT}"
      }
    },
    "browser-use": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "browser-use[cli]",
        "browser-use",
        "--mcp"
      ],
      "env": {
        "ANTHROPIC_BASE_URL": "${input:anthropic-base-url}",
        "ANTHROPIC_AUTH_TOKEN": "${input:anthropic-auth-token}",
        "ANTHROPIC_MODEL": "${input:anthropic-model}"
      }
    },
    "awslabs.document-loader-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.document-loader-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    }
  }
}
