# 實際檔名.env，內容與 .env.example 相同，但變數值替換為實際的 Oracle 資料庫帳號和密碼。
# 開發環境 Oracle 資料庫
ORACLE_DEV_USERNAME=your_dev_username
ORACLE_DEV_PASSWORD=your_dev_password

# 資料庫主機名（dev profile 用）。本地用 IDE / bootRun 直連時「不需要設定」，
# application-dev.yml 會自動 fallback 成 localhost。
# 透過 podman/docker compose 在容器內跑時，compose 會自動帶入 oracle-db（服務名），不必在此設定。
# ORACLE_DB_HOST=localhost

# 測試環境 Oracle 資料庫
ORACLE_TEST_USERNAME=your_test_username
ORACLE_TEST_PASSWORD=your_test_password